{
    "name": "olama-school/weekly-plan",
    "description": "WordPress plugin for school weekly plan management and curriculum",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=7.4",
        "phpoffice/phpspreadsheet": "^1.29",
        "google/apiclient": "^2.15"
    },
    "scripts": {
        "post-update-cmd": [
            "Google\\Task\\ComposerInformation::cleanup"
        ],
        "post-install-cmd": [
            "Google\\Task\\ComposerInformation::cleanup"
        ]
    },
    "extra": {
        "google/apiclient-services": [
            "Drive",
            "Oauth2"
        ]
    },
    "autoload": {
        "classmap": [
            "includes/"
        ]
    }
}